<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="Heimdall.App.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="Heimdall">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid
        x:Name="RootGrid"
        MinWidth="1120"
        MinHeight="720"
        Background="{StaticResource HeimdallPageBackgroundBrush}">

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Left wizard rail. Steps are readable, and future steps are locked until reached through the workflow. -->
        <Border
            Grid.Column="0"
            Background="{StaticResource HeimdallSidebarBrush}"
            BorderBrush="{StaticResource HeimdallGoldBrush}"
            BorderThickness="0,0,1,0">

            <Grid Padding="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Spacing="8">
                    <TextBlock
                        Text="Heimdall"
                        FontSize="30"
                        FontWeight="SemiBold"
                        Foreground="{StaticResource HeimdallSidebarTextBrush}" />

                    <TextBlock
                        Text="New-book email generator"
                        Foreground="{StaticResource HeimdallSidebarMutedTextBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>

                <ProgressBar
                    x:Name="WizardProgressBar"
                    Grid.Row="1"
                    Margin="0,28,0,20"
                    Minimum="1"
                    Maximum="6"
                    Value="1" />

                <ListView
                    x:Name="StepsListView"
                    Grid.Row="2"
                    Background="Transparent"
                    BorderThickness="0"
                    SelectionMode="Single"
                    SelectionChanged="StepsListView_SelectionChanged"
                    ToolTipService.ToolTip="Use this sidebar to return to steps that have already been unlocked.">

                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0,3,0,3" />
                            <Setter Property="MinHeight" Value="54" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>

                <Border
                    Grid.Row="3"
                    Margin="0,20,0,0"
                    Padding="14"
                    CornerRadius="8"
                    Background="#182B46"
                    BorderBrush="#334C70"
                    BorderThickness="1">

                    <StackPanel Spacing="6">
                        <TextBlock
                            Text="Workflow guide"
                            FontWeight="SemiBold"
                            Foreground="{StaticResource HeimdallSidebarTextBrush}" />

                        <TextBlock
                            Text="Complete each step once. After a step is unlocked, you can return to it from the sidebar."
                            FontSize="12"
                            Foreground="{StaticResource HeimdallSidebarMutedTextBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main wizard workspace -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border
                Grid.Row="0"
                Padding="36,30,36,22"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1">

                <StackPanel Spacing="6">
                    <TextBlock
                        x:Name="StepTitleTextBlock"
                        FontSize="30"
                        FontWeight="SemiBold"
                        Text="Start" />

                    <TextBlock
                        x:Name="StepDescriptionTextBlock"
                        FontSize="14"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />

                    <StackPanel
                        Margin="0,12,0,0"
                        Orientation="Horizontal"
                        Spacing="10">

                        <ProgressRing
                            x:Name="BusyProgressRing"
                            Width="20"
                            Height="20"
                            IsActive="False"
                            Visibility="Collapsed" />

                        <TextBlock
                            x:Name="BusyTextBlock"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text=""
                            Visibility="Collapsed" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <InfoBar
                x:Name="StatusInfoBar"
                Grid.Row="1"
                Margin="36,16,36,0"
                IsOpen="False"
                IsClosable="True"
                Severity="Informational"
                Title="Status"
                Message="" />

            <Frame
                x:Name="ContentFrame"
                Grid.Row="2"
                Margin="36,24,36,24" />

            <Border
                Grid.Row="3"
                Padding="36,18"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0">

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        x:Name="ProgressTextBlock"
                        Grid.Column="0"
                        VerticalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="Step 1 of 6" />

                    <StackPanel
                        Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="12">

                        <Button
                            x:Name="BackButton"
                            MinWidth="104"
                            Content="Back"
                            ToolTipService.ToolTip="Return to the previous step."
                            Click="BackButton_Click" />

                        <Button
                            x:Name="NextButton"
                            MinWidth="170"
                            Content="Start workflow"
                            Style="{StaticResource AccentButtonStyle}"
                            ToolTipService.ToolTip="Validate this step and continue."
                            Click="NextButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
