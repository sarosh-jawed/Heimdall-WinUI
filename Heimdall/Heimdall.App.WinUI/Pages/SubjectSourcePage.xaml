<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Heimdall.App.WinUI.Pages.SubjectSourcePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="20" MaxWidth="860">
            <TextBlock
                Text="Choose subject-list source"
                FontSize="24"
                FontWeight="SemiBold" />

            <TextBlock
                Text="Heimdall supports two subject-list modes: generating fresh lists using Bragi core logic, or reading an existing Bragi output folder."
                TextWrapping="Wrap" />

            <StackPanel Spacing="10">
                <TextBlock
                    Text="Subject-list source"
                    FontWeight="SemiBold" />

                <RadioButton
                    x:Name="GenerateFreshRadioButton"
                    Content="Generate fresh Bragi subject lists from the selected FOLIO CSV"
                    GroupName="SubjectSource"
                    IsChecked="True"
                    Checked="SubjectSourceRadioButton_Checked" />

                <RadioButton
                    x:Name="ExistingFolderRadioButton"
                    Content="Use an existing Bragi output folder"
                    GroupName="SubjectSource"
                    Checked="SubjectSourceRadioButton_Checked" />
            </StackPanel>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox
                    x:Name="ExistingBragiFolderTextBox"
                    Grid.Column="0"
                    Header="Existing Bragi subject-list folder"
                    PlaceholderText="No existing Bragi folder selected yet"
                    IsReadOnly="True"
                    IsEnabled="False" />

                <Button
                    x:Name="SelectExistingBragiFolderButton"
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    Content="Select Bragi folder"
                    ToolTipService.ToolTip="Choose an existing folder that contains Bragi subject-list text files."
                    IsEnabled="False"
                    Click="SelectExistingBragiFolderButton_Click" />
            </Grid>

            <Border
                Padding="18"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <StackPanel Spacing="8">
                    <TextBlock
                        Text="Generated/read files"
                        FontSize="18"
                        FontWeight="SemiBold" />

                    <TextBlock Text="ArtSubjects.txt, BusinessSubjects.txt, ComputerSubjects.txt, HistorySubjects.txt, EducationSubjects.txt, SlimSubjects.txt, and other configured category files." TextWrapping="Wrap" />
                    <TextBlock Text="NotCategorizedSubjects.txt and RunSummary.txt are Bragi outputs, but CannotSortBooks.html is generated later by Heimdall at the book-record level." TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <InfoBar
                x:Name="SubjectSourceStatusInfoBar"
                IsOpen="False"
                IsClosable="True"
                Severity="Informational"
                Title="Status"
                Message="" />
        </StackPanel>
    </ScrollViewer>
</Page>
