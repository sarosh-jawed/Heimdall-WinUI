<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Heimdall.App.WinUI.Pages.CategorySelectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="20" MaxWidth="860">
            <TextBlock
                Text="Select broad categories"
                FontSize="24"
                FontWeight="SemiBold" />

            <TextBlock
                Text="Phase 1 supports broad category selection only. Individual subject-heading selection is intentionally out of scope."
                TextWrapping="Wrap" />

            <StackPanel Spacing="4">
                <CheckBox Content="Art" />
                <CheckBox Content="Business" />
                <CheckBox Content="Computer" />
                <CheckBox Content="Education" />
                <CheckBox Content="History" />
                <CheckBox Content="Humanities" />
                <CheckBox Content="Psych" />
                <CheckBox Content="SLIM" />
            </StackPanel>

            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="Multi-match behavior"
                Message="A book may appear in every selected category whose subject list matches the book's subject headings." />
        </StackPanel>
    </ScrollViewer>
</Page>
