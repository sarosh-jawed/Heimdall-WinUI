<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Heimdall.App.WinUI.Pages.CategorySelectionPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="20" MaxWidth="900">
            <TextBlock
                Text="Select broad categories"
                FontSize="24"
                FontWeight="SemiBold" />

            <TextBlock
                Text="Select the broad category headings that should receive generated email files. Individual subject-heading selection is intentionally out of scope for this version."
                TextWrapping="Wrap" />

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="SelectAllButton"
                    Grid.Column="0"
                    Content="Select all"
                    Click="SelectAllButton_Click" />

                <Button
                    x:Name="ClearAllButton"
                    Grid.Column="1"
                    Content="Clear all"
                    Click="ClearAllButton_Click" />

                <TextBlock
                    x:Name="CategoryCountTextBlock"
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="0 categories loaded" />
            </Grid>

            <Border
                Padding="16"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <StackPanel Spacing="12">
                    <TextBlock
                        Text="Available categories"
                        FontSize="18"
                        FontWeight="SemiBold" />

                    <StackPanel
                        x:Name="CategoryCheckBoxPanel"
                        Spacing="8" />
                </StackPanel>
            </Border>

            <InfoBar
                x:Name="CategoryStatusInfoBar"
                IsOpen="False"
                IsClosable="True"
                Severity="Informational"
                Title="Status"
                Message="" />

            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="Multi-match behavior"
                Message="A book may appear in every selected category whose subject list matches the book's subject headings." />
        </StackPanel>
    </ScrollViewer>
</Page>
