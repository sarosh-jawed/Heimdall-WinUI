<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Heimdall.App.WinUI.Pages.ExportFinishPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="20" MaxWidth="980">
            <TextBlock
                Text="Export and finish"
                FontSize="24"
                FontWeight="SemiBold" />

            <TextBlock
                Text="Generate final HTML files, review the run summary, and open the output folder or logs."
                TextWrapping="Wrap" />

            <InfoBar
                x:Name="ExportStatusInfoBar"
                IsOpen="False"
                IsClosable="True"
                Severity="Informational"
                Title="Export status"
                Message="" />

            <Border
                Padding="20"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <StackPanel Spacing="10">
                    <TextBlock
                        Text="Completion status"
                        FontSize="18"
                        FontWeight="SemiBold" />

                    <TextBlock
                        x:Name="CompletionStatusTextBlock"
                        Text="Export has not been run yet."
                        TextWrapping="Wrap" />

                    <TextBlock
                        x:Name="OutputFolderTextBlock"
                        Text="No output folder selected yet."
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="12">
                <Button
                    x:Name="ExportFilesButton"
                    Content="Export Files"
                    Click="ExportFilesButton_Click" />

                <Button
                    x:Name="OpenOutputFolderButton"
                    Content="Open Output Folder"
                    IsEnabled="False"
                    Click="OpenOutputFolderButton_Click" />

                <Button
                    x:Name="OpenLogsButton"
                    Content="Open Logs"
                    Click="OpenLogsButton_Click" />
            </StackPanel>

            <ProgressRing
                x:Name="ExportProgressRing"
                IsActive="False"
                Visibility="Collapsed"
                Width="32"
                Height="32" />

            <Border
                Padding="20"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <StackPanel Spacing="12">
                    <TextBlock
                        Text="Run summary"
                        FontSize="18"
                        FontWeight="SemiBold" />

                    <TextBlock
                        x:Name="RunSummaryDetailsTextBlock"
                        Text="Run summary details will appear after export."
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />

                    <TextBlock
                        x:Name="CannotSortCountTextBlock"
                        Text="CannotSort count: not available yet."
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border
                Padding="20"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <StackPanel Spacing="12">
                    <TextBlock
                        Text="Category counts"
                        FontSize="18"
                        FontWeight="SemiBold" />

                    <TextBlock
                        x:Name="CategoryCountsSummaryTextBlock"
                        Text="Category counts will appear after export."
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />

                    <ListView
                        x:Name="CategoryCountsListView"
                        MaxHeight="220" />
                </StackPanel>
            </Border>

            <Border
                Padding="20"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <StackPanel Spacing="12">
                    <TextBlock
                        Text="Generated files"
                        FontSize="18"
                        FontWeight="SemiBold" />

                    <TextBlock
                        x:Name="GeneratedFilesSummaryTextBlock"
                        Text="No files have been exported yet."
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />

                    <ListView
                        x:Name="GeneratedFilesListView"
                        MaxHeight="260" />
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
