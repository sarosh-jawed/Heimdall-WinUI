<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Heimdall.App.WinUI.Pages.StartPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="22" MaxWidth="920">
            <StackPanel Spacing="8">
                <TextBlock
                    Text="Welcome to Heimdall"
                    FontSize="26"
                    FontWeight="SemiBold" />

                <TextBlock
                    Text="Heimdall creates manual HTML new-book email files from official FOLIO CSV records and Bragi subject lists. The workflow keeps each step clear, reviewable, and safe for staff use."
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>

            <Border Style="{StaticResource HeimdallCardBorderStyle}">
                <StackPanel Spacing="12">
                    <TextBlock
                        Text="What Heimdall will do"
                        FontSize="19"
                        FontWeight="SemiBold" />

                    <TextBlock Text="1. Select FOLIO CSV." TextWrapping="Wrap" />
                    <TextBlock Text="2. Choose the output folder." TextWrapping="Wrap" />
                    <TextBlock Text="3. Generate fresh Bragi subject lists or use an existing Bragi output folder." TextWrapping="Wrap" />
                    <TextBlock Text="4. Select email categories." TextWrapping="Wrap" />
                    <TextBlock Text="5. Preview matched books and remove books from specific category previews when needed." TextWrapping="Wrap" />
                    <TextBlock Text="6. Generate HTML emails, CannotSort output, RunSummary, and logs." TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Style="{StaticResource HeimdallCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock
                            Text="Safe by design"
                            FontSize="18"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Text="The app does not send emails automatically. It generates reviewable HTML files that staff can open, verify, and use manually."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource HeimdallCardBorderStyle}">
                    <StackPanel Spacing="8">
                        <TextBlock
                            Text="Category-aware workflow"
                            FontSize="18"
                            FontWeight="SemiBold" />

                        <TextBlock
                            Text="Books may appear in every selected category they match. Removing a book from one category does not remove it from another."
                            TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="Ready to begin"
                Message="Click Start workflow to select the official FOLIO CSV and output folder." />
        </StackPanel>
    </ScrollViewer>
</Page>
