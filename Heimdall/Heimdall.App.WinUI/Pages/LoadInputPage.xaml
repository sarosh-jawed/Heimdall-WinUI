<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Heimdall.App.WinUI.Pages.LoadInputPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <ScrollViewer>
        <StackPanel Spacing="20" MaxWidth="860">
            <TextBlock
                Text="Select FOLIO CSV"
                FontSize="24"
                FontWeight="SemiBold" />

            <TextBlock
                Text="Select the official FOLIO CSV file and the output folder. Heimdall stores the selected paths for later workflow steps."
                TextWrapping="Wrap" />

            <Grid ColumnSpacing="12" RowSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBox
                    x:Name="CsvPathTextBox"
                    Grid.Row="0"
                    Grid.Column="0"
                    Header="Official FOLIO CSV file"
                    PlaceholderText="No CSV file selected yet"
                    IsReadOnly="True" />

                <Button
                    x:Name="SelectCsvButton"
                    Grid.Row="0"
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    Content="Select FOLIO CSV"
                    ToolTipService.ToolTip="Choose the official FOLIO CSV export file."
                    Click="SelectCsvButton_Click" />

                <TextBox
                    x:Name="OutputFolderTextBox"
                    Grid.Row="1"
                    Grid.Column="0"
                    Header="Output folder"
                    PlaceholderText="No output folder selected yet"
                    IsReadOnly="True" />

                <Button
                    x:Name="SelectOutputFolderButton"
                    Grid.Row="1"
                    Grid.Column="1"
                    VerticalAlignment="Bottom"
                    Content="Choose output folder"
                    ToolTipService.ToolTip="Choose where Heimdall should save generated HTML files and the RunSummary."
                    Click="SelectOutputFolderButton_Click" />
            </Grid>

            <InfoBar
                IsOpen="True"
                IsClosable="False"
                Severity="Informational"
                Title="Expected CSV schema"
                Message="Required columns: instances.title, instances.instance_primary_contributor, instances.notes, instances.subjects, and instances.id." />

            <InfoBar
                x:Name="PathStatusInfoBar"
                IsOpen="False"
                IsClosable="True"
                Severity="Informational"
                Title="Status"
                Message="" />
        </StackPanel>
    </ScrollViewer>
</Page>
