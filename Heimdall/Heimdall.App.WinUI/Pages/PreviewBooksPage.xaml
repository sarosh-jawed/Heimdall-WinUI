<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Heimdall.App.WinUI.Pages.PreviewBooksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="10">
            <TextBlock
                Text="Preview matched books"
                FontSize="24"
                FontWeight="SemiBold" />

            <TextBlock
                Text="Review books grouped by category. Removing a book from one category does not remove it from other matched categories."
                TextWrapping="Wrap" />
        </StackPanel>

        <InfoBar
            x:Name="PreviewStatusInfoBar"
            Grid.Row="1"
            IsOpen="False"
            IsClosable="True"
            Severity="Informational"
            Title="Status"
            Message="" />

        <Grid Grid.Row="2" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="16"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Text="Categories"
                        FontSize="18"
                        FontWeight="SemiBold" />

                    <TextBlock
                        x:Name="PreviewSummaryTextBlock"
                        Grid.Row="1"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />

                    <ListView
                        x:Name="CategoryListView"
                        Grid.Row="2"
                        SelectionMode="Single"
                        SelectionChanged="CategoryListView_SelectionChanged" />
                </Grid>
            </Border>

            <Border
                Grid.Column="1"
                Padding="16"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <Grid RowSpacing="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Spacing="4">
                        <TextBlock
                            x:Name="BookPreviewHeaderTextBlock"
                            Text="Book preview"
                            FontSize="18"
                            FontWeight="SemiBold" />

                        <TextBlock
                            x:Name="BookPreviewCountTextBlock"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <InfoBar
                        x:Name="BookPreviewInfoBar"
                        Grid.Row="1"
                        IsOpen="False"
                        IsClosable="False"
                        Severity="Informational"
                        Title="Preview note"
                        Message="" />

                    <ScrollViewer Grid.Row="2">
                        <StackPanel
                            x:Name="BookCardsPanel"
                            Spacing="12" />
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
