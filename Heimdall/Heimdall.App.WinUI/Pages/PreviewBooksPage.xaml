<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="Heimdall.App.WinUI.Pages.PreviewBooksPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="10">
            <TextBlock
                Text="Preview matched books"
                FontSize="24"
                FontWeight="SemiBold" />

            <TextBlock
                Text="This page will show books grouped by selected category. Removing a book from one category will not remove it from other matched categories."
                TextWrapping="Wrap" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border
                Grid.Column="0"
                Padding="16"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <StackPanel Spacing="8">
                    <TextBlock
                        Text="Categories"
                        FontSize="18"
                        FontWeight="SemiBold" />

                    <ListView>
                        <ListViewItem Content="Art" />
                        <ListViewItem Content="History" />
                        <ListViewItem Content="Education" />
                        <ListViewItem Content="CannotSort" />
                    </ListView>
                </StackPanel>
            </Border>

            <Border
                Grid.Column="1"
                Padding="16"
                CornerRadius="8"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1">

                <StackPanel Spacing="12">
                    <TextBlock
                        Text="Book preview"
                        FontSize="18"
                        FontWeight="SemiBold" />

                    <TextBlock
                        Text="Matched book cards will appear here after the workflow is connected to the UI."
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        TextWrapping="Wrap" />

                    <ListView>
                        <ListViewItem Content="Example: Book title, author, and summary preview" />
                        <ListViewItem Content="Example: Remove button will be added during preview integration" />
                    </ListView>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
